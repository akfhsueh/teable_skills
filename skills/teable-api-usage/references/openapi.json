                        },
                        "maxNumAutomationSendEmail": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "maxRows",
                        "maxSizeAttachments",
                        "maxNumDatabaseConnections",
                        "maxRevisionHistoryDays",
                        "maxAutomationHistoryDays",
                        "automationEnable",
                        "auditLogEnable",
                        "adminPanelEnable",
                        "rowColoringEnable",
