                      {
                        "type": "string",
                        "enum": [
                          "automationMailTransportConfig"
                        ]
                      }
                    ]
                  },
                  "transportConfig": {
                    "type": "object",
                    "properties": {
                      "senderName": {
                        "type": "string"
                      },
                      "sender": {
                        "type": "string"
                      },
                      "host": {
                        "type": "string"
                      },
                      "port": {
                        "type": "number"
                      },
                      "secure": {
                        "type": "boolean"
                      },
                      "auth": {
                        "type": "object",
                        "properties": {
                          "user": {
                            "type": "string"
